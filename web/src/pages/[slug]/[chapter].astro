---
import { getCollection, render } from 'astro:content'
import Base from '../../layouts/Base.astro'
import {
  chaptersForNovel,
  compareNovelsNewestFirst,
  routeSlugForNovel,
  sourceBookKey,
} from '../../lib/novels'

export async function getStaticPaths() {
  const novels = (await getCollection('novels')).sort(compareNovelsNewestFirst)
  const chapters = await getCollection('chapters')

  const novelBySourceKey = Object.fromEntries(novels.map((novel) => [sourceBookKey(novel), novel]))

  return chapters.map(entry => {
    const sourceKey = sourceBookKey(entry)
    const parts = entry.id.split('/')
    const chapterParam = parts.at(-1)!
    const novel = novelBySourceKey[sourceKey]
    const slug = novel ? routeSlugForNovel(novel) : sourceKey
    const siblings = novel ? chaptersForNovel(novel, chapters) : chapters
      .filter((chapter) => sourceBookKey(chapter) === sourceKey)
      .sort((a, b) => a.data.chapter - b.data.chapter)

    const idx = siblings.findIndex(c => c.id === entry.id)
    const prev = idx > 0 ? siblings[idx - 1] : null
    const next = idx < siblings.length - 1 ? siblings[idx + 1] : null

    return {
      params: { slug, chapter: chapterParam },
      props: { entry, novel, prev, next },
    }
  })
}

const { entry, novel, prev, next } = Astro.props
const { Content } = await render(entry)

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const slug = novel ? routeSlugForNovel(novel) : sourceBookKey(entry)
const bookTitle = novel?.data.title ?? slug

function chapterParam(entryId: string) {
  return entryId.split('/').at(-1)!
}
---

<Base
  title={`Ch. ${entry.data.chapter}: ${entry.data.title} — ${bookTitle}`}
  description={`Chapter ${entry.data.chapter} of ${bookTitle} by Noman Stiles.`}
>
  <!-- Reading progress bar (controlled by scroll script below) -->
  <div class="reading-progress-bar" id="rp-bar" aria-hidden="true"></div>

  <!-- Chapter header -->
  <div class="chapter-header">
    <div class="chapter-breadcrumb">
      <a href={`${base}/library`}>Library</a>
      <span class="chapter-breadcrumb__sep">/</span>
      <a href={`${base}/${slug}`}>{bookTitle}</a>
    </div>

    <p class="chapter-header__num">Chapter {entry.data.chapter}</p>
    <h1 class="chapter-header__title">{entry.data.title}</h1>

    <div class="chapter-header__rule"></div>
  </div>

  <section
    class="chapter-narration"
    id="chapter-narration"
    data-book-title={bookTitle}
    data-chapter-title={entry.data.title}
    data-chapter-number={String(entry.data.chapter)}
  >
    <div class="chapter-narration__intro">
      <p class="chapter-narration__eyebrow">Optional narration</p>
      <h2 class="chapter-narration__title">Listen to this chapter</h2>
      <p class="chapter-narration__copy">
        Enable AI narration to load a higher-quality voice in your browser, or use your device's
        built-in speech engine instead. AI narration is optional and only downloads when you ask for it.
      </p>
    </div>

    <div class="chapter-narration__controls">
      <div class="chapter-narration__fallback" id="tts-fallback" hidden>
        <strong id="tts-fallback-title">AI narration is unavailable on this device.</strong>
        <p id="tts-fallback-copy">
          Browser voice is still available and does not require any model download.
        </p>
      </div>

      <div class="chapter-narration__toggles">
        <button type="button" class="btn" id="tts-enable-ai">Enable AI narration</button>
        <button type="button" class="btn btn--ghost" id="tts-enable-native">Use browser voice</button>
        <button type="button" class="btn btn--ghost" id="tts-disable" hidden>Turn narration off</button>
      </div>

      <div class="chapter-narration__loading" id="tts-loading" hidden>
        <div class="chapter-narration__loading-head">
          <strong id="tts-loading-label">Preparing voice engine...</strong>
          <span id="tts-loading-value">0%</span>
        </div>
        <div class="chapter-narration__progress">
          <span id="tts-progress-bar"></span>
        </div>
        <p class="chapter-narration__hint" id="tts-loading-hint">
          First load can take a while and uses extra device memory.
        </p>
      </div>

      <div class="chapter-narration__player" id="tts-player" hidden>
        <div class="chapter-narration__player-bar">
          <div class="chapter-narration__actions">
            <button type="button" class="btn" id="tts-play">Play</button>
            <button type="button" class="btn btn--ghost" id="tts-pause">Pause</button>
            <button type="button" class="btn btn--ghost" id="tts-stop">Stop</button>
          </div>

          <div class="chapter-narration__meta">
            <label class="chapter-narration__field chapter-narration__field--mode">
              <span>Mode</span>
              <select id="tts-mode">
                <option value="ai">AI narration</option>
                <option value="native">Browser voice</option>
              </select>
            </label>

            <label class="chapter-narration__field">
              <span>Voice</span>
              <select id="tts-voice">
                <option value="af_bella">Bella</option>
                <option value="af_sarah">Sarah</option>
                <option value="am_fenrir">Fenrir</option>
                <option value="am_michael">Michael</option>
              </select>
            </label>

            <label class="chapter-narration__field chapter-narration__field--speed">
              <span>Speed</span>
              <div class="chapter-narration__speed">
                <input id="tts-speed" type="range" min="0.8" max="1.3" step="0.05" value="1" />
                <output id="tts-speed-value">1.00x</output>
              </div>
            </label>
          </div>
        </div>

        <p class="chapter-narration__status" id="tts-status">
          Narration is off.
        </p>

        <details class="chapter-narration__debug" id="tts-debug">
          <summary>Debug narration</summary>
          <div class="chapter-narration__debug-body">
            <p class="chapter-narration__debug-line"><strong>Phase:</strong> <span id="tts-debug-phase">idle</span></p>
            <p class="chapter-narration__debug-line"><strong>Engine:</strong> <span id="tts-debug-engine">not loaded</span></p>
            <p class="chapter-narration__debug-line"><strong>Audio:</strong> <span id="tts-debug-audio">stopped</span></p>
            <pre class="chapter-narration__debug-log" id="tts-debug-log">Waiting for narration events...</pre>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Prose body -->
  <article class="chapter-prose">
    <Content />
  </article>

  <!-- Prev / Next navigation -->
  <nav class="chapter-nav" aria-label="Chapter navigation">
    {prev ? (
      <a href={`${base}/${slug}/${chapterParam(prev.id)}`} class="chapter-nav__card chapter-nav__card--prev">
        <span class="chapter-nav__dir">&larr; Previous</span>
        <span class="chapter-nav__title">
          Ch. {prev.data.chapter}: {prev.data.title}
        </span>
      </a>
    ) : (
      <div class="chapter-nav__card chapter-nav__card--empty"></div>
    )}

    {next ? (
      <a href={`${base}/${slug}/${chapterParam(next.id)}`} class="chapter-nav__card chapter-nav__card--next">
        <span class="chapter-nav__dir">Next &rarr;</span>
        <span class="chapter-nav__title">
          Ch. {next.data.chapter}: {next.data.title}
        </span>
      </a>
    ) : (
      <a href={`${base}/${slug}`} class="chapter-nav__card chapter-nav__card--next">
        <span class="chapter-nav__dir">Finished &rarr;</span>
        <span class="chapter-nav__title">Back to {bookTitle}</span>
      </a>
    )}
  </nav>
</Base>

<style>
  .reading-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: var(--progress, 0%);
    background: var(--accent);
    z-index: 200;
    transition: width 0.08s linear;
  }

  .chapter-narration {
    max-width: var(--max-prose);
    margin: 0 auto 2.5rem;
    padding: 0 1.5rem;
    display: grid;
    gap: 1rem;
  }

  .chapter-narration__intro,
  .chapter-narration__controls {
    background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(240,244,255,0.92));
    border: 1px solid var(--border);
    border-radius: 20px;
    box-shadow: var(--shadow-sm);
    padding: 1.2rem 1.25rem;
  }

  .chapter-narration__controls {
    display: grid;
    gap: 0.9rem;
  }

  .chapter-narration__eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .chapter-narration__title {
    margin-top: 0.4rem;
    color: var(--text);
    font-size: clamp(1.25rem, 3vw, 1.7rem);
    letter-spacing: -0.03em;
  }

  .chapter-narration__copy {
    margin-top: 0.6rem;
    color: var(--text-muted);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .chapter-narration__toggles,
  .chapter-narration__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .chapter-narration__fallback {
    border: 1px solid rgba(214, 102, 57, 0.18);
    background: linear-gradient(180deg, rgba(255, 248, 242, 0.96), rgba(255, 243, 233, 0.92));
    border-radius: 16px;
    padding: 0.95rem 1rem;
  }

  .chapter-narration__fallback strong {
    display: block;
    color: #9c4f2e;
    font-size: 0.92rem;
  }

  .chapter-narration__fallback p {
    margin-top: 0.35rem;
    color: var(--text-muted);
    font-size: 0.84rem;
    line-height: 1.55;
  }

  .chapter-narration__loading,
  .chapter-narration__player {
    margin-top: 0.1rem;
  }

  .chapter-narration__loading-head,
  .chapter-narration__status-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .chapter-narration__loading-head strong {
    color: var(--text);
    font-size: 0.92rem;
  }

  .chapter-narration__loading-head span {
    color: var(--text-muted);
    font-size: 0.82rem;
    font-variant-numeric: tabular-nums;
  }

  .chapter-narration__progress {
    height: 8px;
    margin-top: 0.65rem;
    background: rgba(51, 84, 255, 0.1);
    border-radius: 999px;
    overflow: hidden;
  }

  .chapter-narration__progress span {
    display: block;
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--accent), var(--accent-bright));
    border-radius: inherit;
    transition: width 0.2s ease;
  }

  .chapter-narration__hint,
  .chapter-narration__status {
    margin-top: 0.65rem;
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .chapter-narration__debug {
    margin-top: 0.85rem;
    border-top: 1px solid var(--border);
    padding-top: 0.85rem;
  }

  .chapter-narration__debug summary {
    cursor: pointer;
    color: var(--text-muted);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .chapter-narration__debug-body {
    margin-top: 0.75rem;
    display: grid;
    gap: 0.45rem;
  }

  .chapter-narration__debug-line {
    color: var(--text-muted);
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .chapter-narration__debug-line strong {
    color: var(--text);
  }

  .chapter-narration__debug-log {
    margin-top: 0.35rem;
    max-height: 220px;
    overflow: auto;
    padding: 0.85rem;
    border-radius: 12px;
    background: rgba(22, 26, 31, 0.95);
    color: #dbe4ff;
    font-size: 0.75rem;
    line-height: 1.5;
    white-space: pre-wrap;
  }

  .chapter-narration__player-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
  }

  .chapter-narration__meta {
    display: grid;
    grid-template-columns: auto auto minmax(180px, 220px);
    gap: 0.9rem;
    align-items: end;
    flex: 1;
  }

  .chapter-narration__field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .chapter-narration__field span {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }

  .chapter-narration__field select,
  .chapter-narration__field input {
    width: 100%;
  }

  .chapter-narration__field--mode {
    max-width: 150px;
  }

  .chapter-narration__field--speed {
    min-width: 180px;
  }

  .chapter-narration__field select {
    height: 42px;
    padding: 0 0.8rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font: inherit;
  }

  .chapter-narration__speed {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .chapter-narration__field output {
    color: var(--text-muted);
    font-size: 0.82rem;
    font-variant-numeric: tabular-nums;
    min-width: 3.1rem;
    text-align: right;
  }

  @media (max-width: 720px) {
    .chapter-narration__player-bar,
    .chapter-narration__meta {
      grid-template-columns: 1fr;
      flex-direction: column;
      align-items: stretch;
    }

    .chapter-narration__field--mode,
    .chapter-narration__field--speed {
      max-width: none;
      min-width: 0;
    }
  }
</style>

<script>
  const bar = document.getElementById('rp-bar') as HTMLElement | null
  if (bar) {
    function update() {
      const doc = document.documentElement
      const scrolled = doc.scrollTop / (doc.scrollHeight - doc.clientHeight)
      bar!.style.setProperty('--progress', (Math.min(scrolled, 1) * 100).toFixed(1) + '%')
    }
    window.addEventListener('scroll', update, { passive: true })
    update()
  }

  type NarrationMode = 'off' | 'ai' | 'native'

  type StoredPrefs = {
    mode: NarrationMode
    voice: string
    speed: number
  }

  const STORAGE_KEY = 'aiwriter:tts-prefs'
  const narrationRoot = document.getElementById('chapter-narration') as HTMLElement | null

  if (narrationRoot) {
    const enableAiButton = document.getElementById('tts-enable-ai') as HTMLButtonElement
    const enableNativeButton = document.getElementById('tts-enable-native') as HTMLButtonElement
    const disableButton = document.getElementById('tts-disable') as HTMLButtonElement
    const loadingBox = document.getElementById('tts-loading') as HTMLElement
    const loadingLabel = document.getElementById('tts-loading-label') as HTMLElement
    const loadingValue = document.getElementById('tts-loading-value') as HTMLElement
    const loadingHint = document.getElementById('tts-loading-hint') as HTMLElement
    const progressBar = document.getElementById('tts-progress-bar') as HTMLElement
    const fallbackBox = document.getElementById('tts-fallback') as HTMLElement
    const fallbackTitle = document.getElementById('tts-fallback-title') as HTMLElement
    const fallbackCopy = document.getElementById('tts-fallback-copy') as HTMLElement
    const player = document.getElementById('tts-player') as HTMLElement
    const modeSelect = document.getElementById('tts-mode') as HTMLSelectElement
    const voiceSelect = document.getElementById('tts-voice') as HTMLSelectElement
    const speedInput = document.getElementById('tts-speed') as HTMLInputElement
    const speedValue = document.getElementById('tts-speed-value') as HTMLOutputElement
    const playButton = document.getElementById('tts-play') as HTMLButtonElement
    const pauseButton = document.getElementById('tts-pause') as HTMLButtonElement
    const stopButton = document.getElementById('tts-stop') as HTMLButtonElement
    const status = document.getElementById('tts-status') as HTMLElement
    const debugPhase = document.getElementById('tts-debug-phase') as HTMLElement
    const debugEngine = document.getElementById('tts-debug-engine') as HTMLElement
    const debugAudio = document.getElementById('tts-debug-audio') as HTMLElement
    const debugLog = document.getElementById('tts-debug-log') as HTMLElement

    const chapterProse = document.querySelector('.chapter-prose') as HTMLElement | null
    const chapterText = chapterProse?.innerText?.trim() ?? ''
    const chapterHeading = [
      narrationRoot.dataset.bookTitle,
      `Chapter ${narrationRoot.dataset.chapterNumber}`,
      narrationRoot.dataset.chapterTitle,
    ].filter(Boolean).join('. ')
    const narrationText = [chapterHeading, chapterText].filter(Boolean).join('. ')

    let audioUrl: string | null = null
    let audioElement: HTMLAudioElement | null = null
    let headtts: any = null
    let enhancedReady = false
    let enhancedRequested = false
    let nativeUtterance: SpeechSynthesisUtterance | null = null
    let aiModeAllowed = true
    let aiModeReason = ''

    const defaultPrefs: StoredPrefs = {
      mode: 'off',
      voice: 'af_bella',
      speed: 1,
    }

    function readPrefs(): StoredPrefs {
      try {
        const raw = localStorage.getItem(STORAGE_KEY)
        if (!raw) return defaultPrefs
        const parsed = JSON.parse(raw)
        return {
          mode: parsed.mode === 'ai' || parsed.mode === 'native' ? parsed.mode : 'off',
          voice: typeof parsed.voice === 'string' ? parsed.voice : defaultPrefs.voice,
          speed: typeof parsed.speed === 'number' ? parsed.speed : defaultPrefs.speed,
        }
      } catch {
        return defaultPrefs
      }
    }

    function writePrefs(next: StoredPrefs) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(next))
    }

    let prefs = readPrefs()

    voiceSelect.value = prefs.voice
    speedInput.value = String(prefs.speed)
    speedValue.value = `${prefs.speed.toFixed(2)}x`
    modeSelect.value = prefs.mode === 'off' ? 'ai' : prefs.mode

    function setStatus(message: string) {
      status.textContent = message
      logDebug(`status: ${message}`)
    }

    function logDebug(message: string) {
      const timestamp = new Date().toLocaleTimeString()
      debugLog.textContent = `[${timestamp}] ${message}\n${debugLog.textContent}`.trim()
    }

    function setDebugPhase(phase: string) {
      debugPhase.textContent = phase
      logDebug(`phase -> ${phase}`)
    }

    function setDebugEngineState(state: string) {
      debugEngine.textContent = state
      logDebug(`engine -> ${state}`)
    }

    function setDebugAudioState(state: string) {
      debugAudio.textContent = state
      logDebug(`audio -> ${state}`)
    }

    function setFallback(message: string, detail = 'Browser voice is still available and does not require any model download.') {
      fallbackBox.hidden = false
      fallbackTitle.textContent = message
      fallbackCopy.textContent = detail
    }

    function clearFallback() {
      fallbackBox.hidden = true
    }

    function setLoading(progress: number | null, label: string, hint?: string) {
      loadingBox.hidden = false
      loadingLabel.textContent = label
      if (progress === null) {
        loadingValue.textContent = '...'
        progressBar.style.width = '18%'
      } else {
        const clamped = Math.max(0, Math.min(progress, 100))
        loadingValue.textContent = `${clamped}%`
        progressBar.style.width = `${clamped}%`
      }
      if (hint) {
        loadingHint.textContent = hint
      }
    }

    function hideLoading() {
      loadingBox.hidden = true
      progressBar.style.width = '0%'
      setDebugPhase('idle')
    }

    function syncUi(mode: NarrationMode) {
      const active = mode !== 'off'
      player.hidden = !active
      disableButton.hidden = !active
      enableAiButton.hidden = active || !aiModeAllowed
      enableNativeButton.hidden = active
      modeSelect.value = mode === 'off' ? 'ai' : mode
      const nativeOnly = !aiModeAllowed
      const aiOption = modeSelect.querySelector('option[value="ai"]') as HTMLOptionElement | null
      if (aiOption) {
        aiOption.disabled = nativeOnly
      }
      if (nativeOnly && modeSelect.value === 'ai') {
        modeSelect.value = 'native'
      }
    }

    function stopAudioPlayback() {
      if (audioElement) {
        audioElement.pause()
        audioElement.currentTime = 0
      }
      if (audioUrl) {
        URL.revokeObjectURL(audioUrl)
        audioUrl = null
      }
      audioElement = null
      setDebugAudioState('stopped')
    }

    function stopNativePlayback() {
      if ('speechSynthesis' in window) {
        window.speechSynthesis.cancel()
      }
      nativeUtterance = null
      setDebugAudioState('stopped')
    }

    function stopAllPlayback() {
      stopAudioPlayback()
      stopNativePlayback()
    }

    function updateStoredMode(mode: NarrationMode) {
      const safeMode = mode === 'ai' && !aiModeAllowed ? 'native' : mode
      prefs = {
        ...prefs,
        mode: safeMode,
        voice: voiceSelect.value,
        speed: Number(speedInput.value),
      }
      writePrefs(prefs)
      syncUi(safeMode)
    }

    function nativeVoices() {
      if (!('speechSynthesis' in window)) return []
      return window.speechSynthesis.getVoices().filter((voice) => /^en(-|_|$)/i.test(voice.lang))
    }

    function updateVoiceOptions(forMode: NarrationMode) {
      if (forMode === 'ai' && !aiModeAllowed) {
        forMode = 'native'
      }
      const previous = voiceSelect.value
      if (forMode === 'native') {
        const voices = nativeVoices()
        voiceSelect.innerHTML = ''
        for (const voice of voices) {
          const option = document.createElement('option')
          option.value = voice.name
          option.textContent = `${voice.name} (${voice.lang})`
          voiceSelect.append(option)
        }
        if (!voices.length) {
          const option = document.createElement('option')
          option.value = ''
          option.textContent = 'System default'
          voiceSelect.append(option)
        }
        voiceSelect.value = voices.find((voice) => voice.name === previous)?.name || voiceSelect.options[0]?.value || ''
      } else {
        const aiVoices = [
          ['af_bella', 'Bella'],
          ['af_sarah', 'Sarah'],
          ['am_fenrir', 'Fenrir'],
          ['am_michael', 'Michael'],
        ]
        voiceSelect.innerHTML = ''
        for (const [value, label] of aiVoices) {
          const option = document.createElement('option')
          option.value = value
          option.textContent = label
          voiceSelect.append(option)
        }
        voiceSelect.value = aiVoices.some(([value]) => value === previous) ? previous : prefs.voice
      }
    }

    function detectAiNarrationSupport() {
      const nav = navigator as Navigator & { deviceMemory?: number; gpu?: unknown }
      const touchHeavy = nav.maxTouchPoints > 1
      const mobileUA = /Android|iPhone|iPad|iPod/i.test(nav.userAgent)
      const lowCpu = typeof nav.hardwareConcurrency === 'number' && nav.hardwareConcurrency > 0 && nav.hardwareConcurrency < 6
      const lowMemory = typeof nav.deviceMemory === 'number' && nav.deviceMemory > 0 && nav.deviceMemory < 6
      const lacksWebGpu = !('gpu' in nav)

      if (mobileUA || touchHeavy) {
        return {
          allowed: false,
          reason: 'AI narration is disabled on mobile and tablet devices for now.',
          detail: 'The browser voice option is lighter and more reliable on touch devices.',
        }
      }

      if (lacksWebGpu && (lowCpu || lowMemory)) {
        return {
          allowed: false,
          reason: 'AI narration is disabled on lower-power devices.',
          detail: 'This chapter can still be read aloud with your browser voice without downloading the AI model.',
        }
      }

      if (lacksWebGpu) {
        return {
          allowed: true,
          reason: 'AI narration may be slower here because WebGPU is unavailable.',
          detail: 'It can still attempt a WASM fallback, but browser voice will usually feel faster.',
        }
      }

      return { allowed: true, reason: '', detail: '' }
    }

    async function ensureEnhancedEngine() {
      if (!aiModeAllowed) {
        setFallback(aiModeReason || 'AI narration is unavailable on this device.')
        setStatus('Browser voice is available instead.')
        return false
      }
      if (enhancedReady) return true
      if (enhancedRequested) return false

      enhancedRequested = true
      setDebugPhase('loading-engine')
      setDebugEngineState('loading')
      setLoading(2, 'Preparing AI narration...', 'Downloading the Kokoro voice engine in your browser.')
      setStatus('Loading AI narration...')

      try {
        const module = await import('https://cdn.jsdelivr.net/npm/@met4citizen/headtts@1.1/+esm')
        const { HeadTTS } = module
        headtts = new HeadTTS({
          endpoints: ['webgpu', 'wasm'],
          languages: ['en-us'],
          voices: [voiceSelect.value || 'af_bella'],
          defaultVoice: voiceSelect.value || 'af_bella',
          defaultLanguage: 'en-us',
          defaultSpeed: Number(speedInput.value),
          defaultAudioEncoding: 'wav',
          workerModule: 'https://cdn.jsdelivr.net/npm/@met4citizen/headtts@1.1/modules/worker-tts.mjs',
          dictionaryURL: 'https://cdn.jsdelivr.net/npm/@met4citizen/headtts@1.1/dictionaries/',
        })

        await headtts.connect(
          null,
          (event: ProgressEvent<EventTarget>) => {
            const total = typeof event.total === 'number' && event.total > 0 ? event.total : 0
            const loaded = typeof event.loaded === 'number' ? event.loaded : 0
            const progress = total > 0 ? Math.round((loaded / total) * 100) : null
            logDebug(`download progress: ${progress === null ? 'unknown' : `${progress}%`}`)
            setLoading(
              progress,
              'Loading AI narration...',
              'First load can take a while. WebGPU is fastest; WASM is slower but more compatible.',
            )
          },
          () => {
            setLoading(null, 'Still loading AI narration...', 'This can take a while on slower devices.')
          },
        )

        enhancedReady = true
        hideLoading()
        setDebugEngineState('ready')
        setStatus('AI narration is ready on this device.')
        return true
      } catch (error) {
        console.error(error)
        enhancedRequested = false
        hideLoading()
        setDebugEngineState('failed')
        logDebug(`engine error: ${error instanceof Error ? error.message : String(error)}`)
        setFallback(
          'AI narration could not start in this browser.',
          'Browser voice is still available and avoids the large model download.',
        )
        setStatus('AI narration could not start on this device. Browser voice is still available.')
        return false
      }
    }

    function audioBlobFromPayload(payload: any, encoding = 'wav') {
      const mime = encoding === 'wav' ? 'audio/wav' : 'application/octet-stream'
      if (!payload) return null
      if (payload instanceof Blob) return payload
      if (typeof AudioBuffer !== 'undefined' && payload instanceof AudioBuffer) {
        const wav = audioBufferToWav(payload)
        return new Blob([wav], { type: 'audio/wav' })
      }
      if (payload instanceof ArrayBuffer) return new Blob([payload], { type: mime })
      if (ArrayBuffer.isView(payload)) {
        return new Blob([payload.buffer.slice(payload.byteOffset, payload.byteOffset + payload.byteLength)], { type: mime })
      }
      if (Array.isArray(payload)) {
        const parts = payload
          .map((item) => {
            if (item instanceof ArrayBuffer) return item
            if (ArrayBuffer.isView(item)) {
              return item.buffer.slice(item.byteOffset, item.byteOffset + item.byteLength)
            }
            return null
          })
          .filter(Boolean)
        return parts.length ? new Blob(parts as BlobPart[], { type: mime }) : null
      }
      return null
    }

    function audioBufferToWav(buffer: AudioBuffer) {
      const channels = buffer.numberOfChannels
      const sampleRate = buffer.sampleRate
      const frameCount = buffer.length
      const bytesPerSample = 2
      const dataSize = frameCount * channels * bytesPerSample
      const wavBuffer = new ArrayBuffer(44 + dataSize)
      const view = new DataView(wavBuffer)

      function writeString(offset: number, value: string) {
        for (let index = 0; index < value.length; index += 1) {
          view.setUint8(offset + index, value.charCodeAt(index))
        }
      }

      writeString(0, 'RIFF')
      view.setUint32(4, 36 + dataSize, true)
      writeString(8, 'WAVE')
      writeString(12, 'fmt ')
      view.setUint32(16, 16, true)
      view.setUint16(20, 1, true)
      view.setUint16(22, channels, true)
      view.setUint32(24, sampleRate, true)
      view.setUint32(28, sampleRate * channels * bytesPerSample, true)
      view.setUint16(32, channels * bytesPerSample, true)
      view.setUint16(34, bytesPerSample * 8, true)
      writeString(36, 'data')
      view.setUint32(40, dataSize, true)

      let offset = 44
      const channelData = Array.from({ length: channels }, (_, channel) => buffer.getChannelData(channel))

      for (let frame = 0; frame < frameCount; frame += 1) {
        for (let channel = 0; channel < channels; channel += 1) {
          const sample = Math.max(-1, Math.min(1, channelData[channel]![frame] ?? 0))
          const int16 = sample < 0 ? sample * 0x8000 : sample * 0x7fff
          view.setInt16(offset, int16, true)
          offset += bytesPerSample
        }
      }

      return wavBuffer
    }

    async function playEnhancedNarration() {
      const ready = await ensureEnhancedEngine()
      if (!ready || !headtts) {
        updateStoredMode('native')
        updateVoiceOptions('native')
        await playNativeNarration()
        return
      }

      stopAllPlayback()
      setDebugPhase('synthesizing')
      setStatus('Generating chapter audio...')
      setLoading(null, 'Generating chapter audio...', 'This happens entirely in your browser.')

      try {
        await headtts.setup({
          voice: voiceSelect.value || 'af_bella',
          language: 'en-us',
          speed: Number(speedInput.value),
          audioEncoding: 'wav',
        })
        logDebug(`setup voice=${voiceSelect.value || 'af_bella'} speed=${Number(speedInput.value).toFixed(2)}`)

        const messages = await headtts.synthesize({ input: narrationText })
        logDebug(`synthesize returned ${Array.isArray(messages) ? messages.length : 0} message(s)`)
        const audioMessage = messages.find((message: any) => message.type === 'audio' && message.data?.audio)
        const blob = audioBlobFromPayload(audioMessage?.data?.audio, audioMessage?.data?.audioEncoding || 'wav')

        hideLoading()

        if (!blob) {
          logDebug('no playable audio payload found')
          throw new Error('No playable audio payload returned from AI narration engine.')
        }

        logDebug(`audio blob size=${blob.size}`)
        audioUrl = URL.createObjectURL(blob)
        audioElement = new Audio(audioUrl)
        audioElement.onplay = () => setDebugAudioState('playing')
        audioElement.onpause = () => setDebugAudioState('paused')
        audioElement.onerror = () => {
          setDebugAudioState('error')
          logDebug('audio element error fired')
        }
        audioElement.onended = () => {
          setDebugAudioState('ended')
          setStatus('AI narration finished.')
        }
        await audioElement.play()
        setDebugPhase('playing')
        setStatus('Playing AI narration.')
      } catch (error) {
        console.error(error)
        hideLoading()
        setDebugPhase('fallback-native')
        logDebug(`synthesis error: ${error instanceof Error ? error.message : String(error)}`)
        setStatus('AI narration failed for this chapter. Falling back to browser voice.')
        updateStoredMode('native')
        updateVoiceOptions('native')
        await playNativeNarration()
      }
    }

    async function playNativeNarration() {
      if (!('speechSynthesis' in window)) {
        setStatus('This browser does not support speech synthesis.')
        return
      }

      stopAllPlayback()
      setDebugPhase('native-speaking')
      const utterance = new SpeechSynthesisUtterance(narrationText)
      utterance.rate = Number(speedInput.value)
      const voice = nativeVoices().find((item) => item.name === voiceSelect.value)
      if (voice) {
        utterance.voice = voice
      }
      utterance.onstart = () => {
        setDebugAudioState('playing')
        setStatus('Playing browser voice.')
      }
      utterance.onend = () => {
        setDebugAudioState('ended')
        setStatus('Browser voice finished.')
      }
      utterance.onerror = (event) => {
        setDebugAudioState('error')
        logDebug(`browser voice error: ${String((event as SpeechSynthesisErrorEvent).error || 'unknown')}`)
        setStatus('Browser voice playback failed.')
      }
      nativeUtterance = utterance
      window.speechSynthesis.cancel()
      window.speechSynthesis.speak(utterance)
    }

    enableAiButton.addEventListener('click', async () => {
      if (!aiModeAllowed) {
        updateStoredMode('native')
        updateVoiceOptions('native')
        setFallback(aiModeReason || 'AI narration is unavailable on this device.')
        setStatus('Browser voice enabled instead.')
        return
      }
      clearFallback()
      updateStoredMode('ai')
      updateVoiceOptions('ai')
      setStatus('AI narration enabled. Press play to download the voice engine.')
      await ensureEnhancedEngine()
    })

    enableNativeButton.addEventListener('click', () => {
      updateStoredMode('native')
      updateVoiceOptions('native')
      if (!aiModeAllowed) {
        setFallback(aiModeReason || 'AI narration is unavailable on this device.')
      } else {
        clearFallback()
      }
      setStatus('Browser voice enabled.')
    })

    disableButton.addEventListener('click', () => {
      stopAllPlayback()
      updateStoredMode('off')
      hideLoading()
      if (!aiModeAllowed) {
        setFallback(aiModeReason || 'AI narration is unavailable on this device.')
      } else {
        clearFallback()
      }
      setStatus('Narration is off.')
    })

    modeSelect.addEventListener('change', async () => {
      const mode = modeSelect.value === 'native' || !aiModeAllowed ? 'native' : 'ai'
      updateStoredMode(mode)
      updateVoiceOptions(mode)
      if (mode === 'ai') {
        clearFallback()
        setStatus('AI narration enabled. Press play to begin.')
      } else {
        if (!aiModeAllowed) {
          setFallback(aiModeReason || 'AI narration is unavailable on this device.')
        }
        setStatus('Browser voice enabled.')
      }
    })

    voiceSelect.addEventListener('change', () => {
      prefs = { ...prefs, voice: voiceSelect.value }
      writePrefs({ ...prefs, speed: Number(speedInput.value), mode: prefs.mode })
    })

    speedInput.addEventListener('input', () => {
      const speed = Number(speedInput.value)
      speedValue.value = `${speed.toFixed(2)}x`
      prefs = { ...prefs, speed }
      writePrefs({ ...prefs, voice: voiceSelect.value, mode: prefs.mode })
    })

    playButton.addEventListener('click', async () => {
      const mode = (modeSelect.value === 'native' ? 'native' : 'ai') as NarrationMode
      updateStoredMode(mode)
      if (mode === 'ai') {
        await playEnhancedNarration()
      } else {
        await playNativeNarration()
      }
    })

    pauseButton.addEventListener('click', () => {
      if (modeSelect.value === 'native' && 'speechSynthesis' in window) {
        if (window.speechSynthesis.speaking && !window.speechSynthesis.paused) {
          window.speechSynthesis.pause()
          setDebugAudioState('paused')
          setStatus('Browser voice paused.')
        } else if (window.speechSynthesis.paused) {
          window.speechSynthesis.resume()
          setDebugAudioState('playing')
          setStatus('Browser voice resumed.')
        }
        return
      }

      if (audioElement) {
        if (audioElement.paused) {
          audioElement.play().catch(() => {
            setDebugAudioState('error')
            setStatus('Could not resume AI narration.')
          })
          setDebugAudioState('playing')
          setStatus('Playing AI narration.')
        } else {
          audioElement.pause()
          setStatus('AI narration paused.')
        }
      }
    })

    stopButton.addEventListener('click', () => {
      stopAllPlayback()
      setDebugPhase('idle')
      setStatus('Narration stopped.')
    })

    if ('speechSynthesis' in window) {
      window.speechSynthesis.onvoiceschanged = () => {
        if ((modeSelect.value as NarrationMode) === 'native') {
          updateVoiceOptions('native')
        }
      }
    }

    {
      const support = detectAiNarrationSupport()
      aiModeAllowed = support.allowed
      aiModeReason = support.reason
      if (!support.allowed) {
        setFallback(support.reason, support.detail)
      } else if (support.reason) {
        setFallback(support.reason, support.detail)
      }
    }

    syncUi(prefs.mode)
    if (prefs.mode === 'native' || !aiModeAllowed) {
      updateStoredMode('native')
      updateVoiceOptions('native')
      setDebugEngineState(aiModeAllowed ? 'optional' : 'unavailable')
      setStatus('Browser voice is enabled.')
    } else if (prefs.mode === 'ai') {
      updateVoiceOptions('ai')
      setDebugEngineState('not loaded')
      setStatus('AI narration is enabled. Press play to load the voice engine.')
    } else {
      updateVoiceOptions('ai')
      setDebugEngineState(aiModeAllowed ? 'not loaded' : 'unavailable')
      setStatus('Narration is off.')
    }
  }
</script>
