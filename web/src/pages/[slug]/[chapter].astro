---
import { getCollection, render } from 'astro:content'
import Base from '../../layouts/Base.astro'
import {
  chaptersForNovel,
  compareNovelsNewestFirst,
  routeSlugForNovel,
  sourceBookKey,
} from '../../lib/novels'

export async function getStaticPaths() {
  const novels = (await getCollection('novels')).sort(compareNovelsNewestFirst)
  const chapters = await getCollection('chapters')

  const novelBySourceKey = Object.fromEntries(novels.map((novel) => [sourceBookKey(novel), novel]))

  return chapters.map(entry => {
    const sourceKey = sourceBookKey(entry)
    const parts = entry.id.split('/')
    const chapterParam = parts.at(-1)!
    const novel = novelBySourceKey[sourceKey]
    const slug = novel ? routeSlugForNovel(novel) : sourceKey
    const siblings = novel ? chaptersForNovel(novel, chapters) : chapters
      .filter((chapter) => sourceBookKey(chapter) === sourceKey)
      .sort((a, b) => a.data.chapter - b.data.chapter)

    const idx = siblings.findIndex(c => c.id === entry.id)
    const prev = idx > 0 ? siblings[idx - 1] : null
    const next = idx < siblings.length - 1 ? siblings[idx + 1] : null

    return {
      params: { slug, chapter: chapterParam },
      props: { entry, novel, prev, next },
    }
  })
}

const { entry, novel, prev, next } = Astro.props
const { Content } = await render(entry)

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const slug = novel ? routeSlugForNovel(novel) : sourceBookKey(entry)
const bookTitle = novel?.data.title ?? slug

function chapterParam(entryId: string) {
  return entryId.split('/').at(-1)!
}
---

<Base
  title={`Ch. ${entry.data.chapter}: ${entry.data.title} — ${bookTitle}`}
  description={`Chapter ${entry.data.chapter} of ${bookTitle} by Noman Stiles.`}
  bodyClass="reader-page"
>
  <div class="reading-progress-bar" id="rp-bar" aria-hidden="true"></div>

  <div class="chapter-header">
    <div class="chapter-header__top">
      <div class="chapter-breadcrumb">
        <a href={`${base}/library`}>Library</a>
        <span class="chapter-breadcrumb__sep">/</span>
        <a href={`${base}/${slug}`}>{bookTitle}</a>
      </div>

      <div class="chapter-font-controls" aria-label="Font size controls">
        <button type="button" class="chapter-font-controls__btn" id="reader-font-down" aria-label="Decrease font size">
          -
        </button>
        <button type="button" class="chapter-font-controls__btn" id="reader-font-up" aria-label="Increase font size">
          +
        </button>
      </div>
    </div>

    <p class="chapter-header__num">Chapter {entry.data.chapter}</p>
    <h1 class="chapter-header__title">{entry.data.title}</h1>

    <div class="chapter-header__rule"></div>
  </div>

  <article class="chapter-prose">
    <Content />
  </article>

  <nav class="chapter-nav" aria-label="Chapter navigation">
    {prev ? (
      <a href={`${base}/${slug}/${chapterParam(prev.id)}`} class="chapter-nav__card chapter-nav__card--prev">
        <span class="chapter-nav__dir">&larr; Previous</span>
        <span class="chapter-nav__title">
          Ch. {prev.data.chapter}: {prev.data.title}
        </span>
      </a>
    ) : (
      <div class="chapter-nav__card chapter-nav__card--empty"></div>
    )}

    {next ? (
      <a href={`${base}/${slug}/${chapterParam(next.id)}`} class="chapter-nav__card chapter-nav__card--next">
        <span class="chapter-nav__dir">Next &rarr;</span>
        <span class="chapter-nav__title">
          Ch. {next.data.chapter}: {next.data.title}
        </span>
      </a>
    ) : (
      <a href={`${base}/${slug}`} class="chapter-nav__card chapter-nav__card--next">
        <span class="chapter-nav__dir">Finished &rarr;</span>
        <span class="chapter-nav__title">Back to {bookTitle}</span>
      </a>
    )}
  </nav>
</Base>

<style>
  body.reader-page {
    --reader-bg: #f8f9fb;
    --reader-surface: rgba(255, 255, 255, 0.82);
    --reader-border: rgba(0, 0, 0, 0.08);
    --reader-title: var(--text);
    --reader-copy: #20252d;
    --reader-muted: var(--text-muted);
    --reader-font-scale: 1;
    background:
      radial-gradient(circle at top, rgba(91, 127, 255, 0.08), transparent 26%),
      var(--reader-bg);
    transition: background 0.25s ease, color 0.25s ease;
  }

  body.reader-page::before {
    background-image: radial-gradient(rgba(95, 114, 148, 0.14) 1px, transparent 1px);
    opacity: 0.45;
  }

  body.reader-page[data-site-theme='dark'] {
    --reader-bg: #10141c;
    --reader-surface: rgba(17, 23, 33, 0.88);
    --reader-border: rgba(129, 153, 196, 0.16);
    --reader-title: #f1f5ff;
    --reader-copy: #dbe4f8;
    --reader-muted: #9cadcc;
  }

  body.reader-page[data-site-theme='dark'] .site-header.is-scrolled {
    background: rgba(16, 20, 28, 0.86);
    border-bottom-color: var(--reader-border);
  }

  body.reader-page[data-site-theme='dark'] .site-header__brand-name,
  body.reader-page[data-site-theme='dark'] .site-header__nav a,
  body.reader-page[data-site-theme='dark'] .chapter-header__title,
  body.reader-page[data-site-theme='dark'] .chapter-nav__dir {
    color: #f1f5ff;
  }

  body.reader-page[data-site-theme='dark'] .site-header__brand-sub,
  body.reader-page[data-site-theme='dark'] .site-footer__copy,
  body.reader-page[data-site-theme='dark'] .chapter-breadcrumb,
  body.reader-page[data-site-theme='dark'] .chapter-breadcrumb a,
  body.reader-page[data-site-theme='dark'] .chapter-nav__title,
  body.reader-page[data-site-theme='dark'] .chapter-header__num {
    color: var(--reader-muted);
  }

  body.reader-page[data-site-theme='dark'] .site-footer {
    background: rgba(17, 23, 33, 0.92);
    border-top-color: var(--reader-border);
  }

  .reading-progress-bar {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: var(--progress, 0%);
    background: var(--accent);
    z-index: 200;
    transition: width 0.08s linear;
  }

  .chapter-header {
    max-width: calc(var(--max-prose) + 6rem);
    margin-top: 0.5rem;
    padding-bottom: 2rem;
  }

  .chapter-header__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .chapter-font-controls {
    display: inline-flex;
    gap: 0.45rem;
  }

  .chapter-font-controls__btn {
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--reader-border);
    border-radius: 999px;
    background: var(--reader-surface);
    color: var(--reader-title);
    box-shadow: var(--shadow-sm);
    font: inherit;
    font-size: 1rem;
    cursor: pointer;
    transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  }

  .chapter-font-controls__btn:hover {
    transform: translateY(-1px);
    border-color: var(--border-accent);
  }

  .chapter-header__title {
    color: var(--reader-title);
    letter-spacing: -0.04em;
    text-wrap: balance;
    max-width: 16ch;
  }

  .chapter-header__num {
    color: var(--accent);
  }

  .chapter-header__rule {
    border-top-color: var(--reader-border);
    opacity: 1;
    width: 56px;
  }

  .chapter-prose {
    color: var(--reader-copy);
    font-size: calc(clamp(1.05rem, 2.2vw, 1.2rem) * var(--reader-font-scale));
    line-height: 1.95;
    padding-bottom: 5rem;
  }

  .chapter-prose p {
    margin-bottom: 1.55rem;
  }

  .chapter-prose h2,
  .chapter-prose h3 {
    color: var(--reader-title);
  }

  .chapter-prose hr {
    border-top-color: var(--reader-border);
    width: 6rem;
    margin: 3rem auto;
  }

  .chapter-nav {
    max-width: calc(var(--max-prose) + 6rem);
    padding-bottom: 5rem;
  }

  .chapter-nav__card {
    background: var(--reader-surface);
    border-color: var(--reader-border);
    backdrop-filter: blur(12px);
  }

  .chapter-nav__title {
    color: var(--reader-muted);
  }

  @media (max-width: 900px) {
    .chapter-header,
    .chapter-nav {
      max-width: var(--max-prose);
    }
  }

  @media (max-width: 640px) {
    .chapter-header__top {
      align-items: flex-start;
      flex-direction: column;
    }

    .chapter-header {
      padding-bottom: 1.6rem;
    }

    .chapter-header__title {
      max-width: none;
    }
  }
</style>

<script>
  const bar = document.getElementById('rp-bar') as HTMLElement | null
  if (bar) {
    function update() {
      const doc = document.documentElement
      const scrolled = doc.scrollTop / (doc.scrollHeight - doc.clientHeight)
      bar!.style.setProperty('--progress', (Math.min(scrolled, 1) * 100).toFixed(1) + '%')
    }
    window.addEventListener('scroll', update, { passive: true })
    update()
  }

  const READER_STORAGE_KEY = 'aiwriter:reader-prefs'
  const fontDown = document.getElementById('reader-font-down') as HTMLButtonElement | null
  const fontUp = document.getElementById('reader-font-up') as HTMLButtonElement | null

  if (fontDown && fontUp) {
    const body = document.body
    const defaultPrefs = { fontScale: 1 }

    function readPrefs() {
      try {
        const raw = localStorage.getItem(READER_STORAGE_KEY)
        if (!raw) return defaultPrefs
        const parsed = JSON.parse(raw)
        return {
          fontScale: typeof parsed.fontScale === 'number' ? parsed.fontScale : 1,
        }
      } catch {
        return defaultPrefs
      }
    }

    function writePrefs(fontScale: number) {
      localStorage.setItem(READER_STORAGE_KEY, JSON.stringify({ fontScale }))
    }

    function applyPrefs(fontScale: number) {
      const clampedScale = Math.max(0.9, Math.min(1.3, Number(fontScale.toFixed(2))))
      body.style.setProperty('--reader-font-scale', String(clampedScale))
      writePrefs(clampedScale)
    }

    let prefs = readPrefs()
    applyPrefs(prefs.fontScale)

    fontDown.addEventListener('click', () => {
      prefs = { ...prefs, fontScale: prefs.fontScale - 0.08 }
      applyPrefs(prefs.fontScale)
    })

    fontUp.addEventListener('click', () => {
      prefs = { ...prefs, fontScale: prefs.fontScale + 0.08 }
      applyPrefs(prefs.fontScale)
    })
  }
</script>
