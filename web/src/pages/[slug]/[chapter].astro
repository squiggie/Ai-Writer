---
import { getCollection, render } from 'astro:content'
import Base from '../../layouts/Base.astro'

export async function getStaticPaths() {
  const novels = await getCollection('novels')
  const chapters = await getCollection('chapters')

  // Build a slug lookup from novel data
  const novelBySlug = Object.fromEntries(novels.map(n => [n.data.slug, n]))

  return chapters.map(entry => {
    // entry.id: "the-remnant-protocol/chapters/chapter-01"
    const parts = entry.id.split('/')
    const slug = parts[0]
    const chapterParam = parts.at(-1)! // "chapter-01"
    const novel = novelBySlug[slug]

    // Sorted sibling chapters for prev/next
    const siblings = chapters
      .filter(c => c.id.startsWith(slug + '/chapters/'))
      .sort((a, b) => a.data.chapter - b.data.chapter)

    const idx = siblings.findIndex(c => c.id === entry.id)
    const prev = idx > 0 ? siblings[idx - 1] : null
    const next = idx < siblings.length - 1 ? siblings[idx + 1] : null

    return {
      params: { slug, chapter: chapterParam },
      props: { entry, novel, prev, next },
    }
  })
}

const { entry, novel, prev, next } = Astro.props
const { Content } = await render(entry)

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const slug = novel?.data.slug ?? entry.id.split('/')[0]

function chapterParam(entryId: string) {
  return entryId.split('/').at(-1)!
}
---

<Base
  title={`Chapter ${entry.data.chapter}: ${entry.data.title} — ${novel?.data.title ?? slug}`}
  description={`Chapter ${entry.data.chapter} of ${novel?.data.title ?? slug}.`}
>
  <div class="chapter-prose">
    <div class="chapter-breadcrumb">
      <a href={`${base}/library`}>Library</a>
      {' / '}
      <a href={`${base}/${slug}`}>{novel?.data.title ?? slug}</a>
    </div>

    <Content />

    <nav class="chapter-nav">
      {prev
        ? <a href={`${base}/${slug}/${chapterParam(prev.id)}`}>
            &larr; Chapter {prev.data.chapter}: {prev.data.title}
          </a>
        : <span />
      }
      {next && (
        <a href={`${base}/${slug}/${chapterParam(next.id)}`} class="chapter-nav__next">
          Chapter {next.data.chapter}: {next.data.title} &rarr;
        </a>
      )}
    </nav>
  </div>
</Base>

<style>
  .chapter-breadcrumb {
    font-size: 0.8rem;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .chapter-breadcrumb a { color: var(--text-muted); }
  .chapter-breadcrumb a:hover { color: var(--accent); text-decoration: none; }
</style>
