---
import { getCollection, render } from 'astro:content'
import Base from '../../layouts/Base.astro'
import CoverPlaceholder from '../../components/CoverPlaceholder.astro'

export async function getStaticPaths() {
  const novels = await getCollection('novels')
  const chapters = await getCollection('chapters')

  return novels.map(novel => {
    const slug = novel.data.slug
    const bookChapters = chapters
      .filter(c => c.id.startsWith(slug + '/chapters/'))
      .sort((a, b) => a.data.chapter - b.data.chapter)
    return { params: { slug }, props: { novel, chapters: bookChapters } }
  })
}

const { novel, chapters } = Astro.props
const { Content } = await render(novel)

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const slug = novel.data.slug

const totalWords = chapters.reduce((sum, c) => sum + (c.data.word_count ?? 0), 0)

function chapterParam(entryId: string) {
  return entryId.split('/').at(-1)!
}
---

<Base
  title={`${novel.data.title} — Nobody Publishing`}
  description={novel.data.synopsis ?? `${novel.data.genre} novel by Noman Stiles. ${novel.data.tone}.`}
>
  <div class="container">
    <!-- Book hero -->
    <div class="book-hero">
      <CoverPlaceholder title={novel.data.title} />

      <div class="book-hero__meta">
        <p class="eyebrow">
          <a href={`${base}/library`} style="color: var(--text-subtle); transition: color 0.15s ease;">
            Library
          </a>
          &nbsp;/&nbsp; {novel.data.genre}
        </p>

        <h1 class="book-hero__title">{novel.data.title}</h1>

        <div class="book-hero__tags">
          <span class="tag">{novel.data.pov}</span>
          <span class="tag">{novel.data.tone}</span>
          {novel.data.setting_type && <span class="tag">{novel.data.setting_type}</span>}
        </div>

        {novel.data.comp_authors && (
          <p style="font-family: var(--font-serif); font-style: italic; font-size: 0.9rem; color: var(--text-muted);">
            In the tradition of {novel.data.comp_authors}
          </p>
        )}

        {novel.data.synopsis && (
          <p class="book-hero__synopsis">{novel.data.synopsis}</p>
        )}

        <p style="font-size: 0.78rem; color: var(--text-subtle);">
          {chapters.length} {chapters.length === 1 ? 'chapter' : 'chapters'}
          {totalWords > 0 && ` · ~${Math.round(totalWords / 1000)}k words`}
          &nbsp;&mdash;&nbsp; Noman Stiles
        </p>

        <div class="book-hero__actions">
          {chapters.length > 0 && (
            <a
              href={`${base}/${slug}/${chapterParam(chapters[0].id)}`}
              class="btn"
            >
              Start reading
            </a>
          )}
          {novel.data.buy_url && (
            <a
              href={novel.data.buy_url}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn--ghost"
            >
              Buy in print &nearr;
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Premise / full synopsis from idea.md body -->
    <div class="book-body">
      <Content />
    </div>

    <!-- Chapter list -->
    {chapters.length > 0 && (
      <div style="margin-top: 3rem; margin-bottom: 2rem;">
        <p class="section-label">Chapters</p>
        <ul class="chapter-list">
          {chapters.map(chapter => (
            <li class="chapter-list__item">
              <a
                href={`${base}/${slug}/${chapterParam(chapter.id)}`}
                class="chapter-list__link"
              >
                <span class="chapter-list__num">
                  {String(chapter.data.chapter).padStart(2, '0')}
                </span>
                <span class="chapter-list__title">{chapter.data.title}</span>
                {chapter.data.word_count && (
                  <span class="chapter-list__words">
                    {chapter.data.word_count.toLocaleString()} words
                  </span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</Base>

<style>
  .book-hero .cover-placeholder { width: 100%; }

  .book-hero__meta a:hover { color: var(--accent) !important; }
</style>
