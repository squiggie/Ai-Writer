---
import { getCollection } from 'astro:content'
import Base from '../layouts/Base.astro'
import CoverPlaceholder from '../components/CoverPlaceholder.astro'

const novels = await getCollection('novels')
const chapters = await getCollection('chapters')

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const books = novels.map(novel => ({
  ...novel,
  chapterCount: chapters.filter(c => c.id.startsWith(novel.data.slug + '/chapters/')).length,
  wordCount: chapters
    .filter(c => c.id.startsWith(novel.data.slug + '/chapters/'))
    .reduce((sum, c) => sum + (c.data.word_count ?? 0), 0),
}))
---

<Base
  title="Library — Nobody Publishing"
  description="All published novels by Noman Stiles. Science fiction with a Christian worldview."
>
  <div class="container--wide">
    <div class="page-header">
      <p class="eyebrow">Nobody Publishing</p>
      <h1 class="page-header__title">Library</h1>
      <p class="page-header__sub">
        {books.length} {books.length === 1 ? 'novel' : 'novels'} by Noman Stiles
      </p>
    </div>

    {books.length === 0 && (
      <div style="text-align: center; padding: 6rem 0; color: var(--text-subtle);">
        <p style="font-family: var(--font-serif); font-style: italic; font-size: 1.25rem;">
          Nothing published yet.
        </p>
        <p style="font-size: 0.85rem; margin-top: 0.5rem;">Check back soon.</p>
      </div>
    )}

    <div class="book-grid">
      {books.map(book => (
        <a href={`${base}/${book.data.slug}`} style="text-decoration: none; display: flex;">
          <article class="book-card" style="width: 100%;">
            <div class="book-card__cover">
              {book.data.cover
                ? <img src={`${base}${book.data.cover}`} alt={`Cover of ${book.data.title}`} class="book-card__cover-img" />
                : <CoverPlaceholder title={book.data.title} />}
            </div>
            <div class="book-card__body">
              <p class="book-card__genre">{book.data.genre}</p>
              <h2 class="book-card__title">{book.data.title}</h2>
              {book.data.comp_authors && (
                <p class="book-card__comp">In the tradition of {book.data.comp_authors}</p>
              )}
              {book.data.synopsis && (
                <p style="font-size: 0.83rem; color: var(--text-muted); line-height: 1.6; flex: 1;">
                  {book.data.synopsis.length > 120
                    ? book.data.synopsis.slice(0, 120) + '…'
                    : book.data.synopsis}
                </p>
              )}
              <div class="book-card__footer">
                <span class="book-card__stat">
                  {book.chapterCount} {book.chapterCount === 1 ? 'chapter' : 'chapters'}
                  {book.wordCount > 0 && ` · ${Math.round(book.wordCount / 1000)}k words`}
                </span>
                <span class="book-card__cta">Read &rarr;</span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</Base>
