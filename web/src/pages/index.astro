---
import { getCollection } from 'astro:content'
import Base from '../layouts/Base.astro'
import CoverPlaceholder from '../components/CoverPlaceholder.astro'

const novels = await getCollection('novels')
const chapters = await getCollection('chapters')

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const totalChapters = chapters.length
const totalWords = chapters.reduce((sum, c) => sum + (c.data.word_count ?? 0), 0)
const featured = novels[0]
const featuredChapters = featured
  ? chapters.filter(c => c.id.startsWith(featured.data.slug + '/chapters/')).length
  : 0
---

<Base title="Nobody Publishing — Noman Stiles">
  <!-- Hero -->
  <section class="hero container--wide">
    <p class="hero__publisher">Nobody Publishing</p>
    <h1 class="hero__name">Noman Stiles</h1>
    <p class="hero__tagline">
      Science fiction with a Christian worldview. Novels written at the intersection of
      conscience, consequence, and quiet grace.
    </p>
    <div class="hero__actions">
      <a href={`${base}/library`} class="btn">Browse the library</a>
      {featured && (
        <a href={`${base}/${featured.data.slug}`} class="btn btn--ghost">
          Latest novel &rarr;
        </a>
      )}
    </div>
    <hr class="hero__divider" />

    <!-- Stats -->
    {(novels.length > 0 || totalChapters > 0) && (
      <div class="stats-bar" style="margin-bottom: 4rem;">
        <div class="stats-bar__item">
          <span class="stats-bar__num">{novels.length}</span>
          <span class="stats-bar__label">{novels.length === 1 ? 'Novel' : 'Novels'}</span>
        </div>
        <div class="stats-bar__item">
          <span class="stats-bar__num">{totalChapters}</span>
          <span class="stats-bar__label">{totalChapters === 1 ? 'Chapter' : 'Chapters'}</span>
        </div>
        {totalWords > 0 && (
          <div class="stats-bar__item">
            <span class="stats-bar__num">{Math.round(totalWords / 1000)}k</span>
            <span class="stats-bar__label">Words</span>
          </div>
        )}
      </div>
    )}

    <!-- Featured novel -->
    {featured && (
      <div style="margin-bottom: 2rem;">
        <p class="section-label">Featured work</p>
        <a href={`${base}/${featured.data.slug}`} style="display: block; text-decoration: none;">
          <article class="featured-book">
            <CoverPlaceholder title={featured.data.title} />
            <div class="featured-book__meta">
              <p class="featured-book__genre">{featured.data.genre}</p>
              <h2 class="featured-book__title">{featured.data.title}</h2>
              {featured.data.comp_authors && (
                <p class="featured-book__comp">
                  In the tradition of {featured.data.comp_authors}
                </p>
              )}
              {featured.data.synopsis ? (
                <p class="featured-book__synopsis">{featured.data.synopsis}</p>
              ) : (
                <p class="featured-book__synopsis" style="color: var(--text-subtle); font-style: italic;">
                  {featured.data.tone} &mdash; {featured.data.setting_type}
                </p>
              )}
              <div class="featured-book__actions">
                <span class="btn btn--sm">Read now</span>
                {featured.data.buy_url && (
                  <span class="btn btn--ghost btn--sm">Buy in print</span>
                )}
              </div>
              <p style="font-size: 0.78rem; color: var(--text-subtle); margin-top: 0.25rem;">
                {featuredChapters} {featuredChapters === 1 ? 'chapter' : 'chapters'} available
              </p>
            </div>
          </article>
        </a>
      </div>
    )}
  </section>
</Base>
