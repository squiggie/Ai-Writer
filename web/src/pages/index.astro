---
import { getCollection } from 'astro:content'
import Base from '../layouts/Base.astro'
import CoverPlaceholder from '../components/CoverPlaceholder.astro'
import {
  chaptersForNovel,
  compareNovelsNewestFirst,
  coverUrlForNovel,
  routeSlugForNovel,
  totalWordsForChapters,
} from '../lib/novels'

const novels = (await getCollection('novels')).sort(compareNovelsNewestFirst)
const chapters = await getCollection('chapters')

const base = import.meta.env.BASE_URL.replace(/\/$/, '')

const totalChapters = chapters.length
const totalWords = totalWordsForChapters(chapters)
const featured = novels[0]
const featuredSlug = featured ? routeSlugForNovel(featured) : null
const featuredChapters = featured ? chaptersForNovel(featured, chapters) : []
const featuredCover = featured ? coverUrlForNovel(featured) : null

const recentBooks = novels.slice(0, 5).map((novel) => {
  const bookChapters = chaptersForNovel(novel, chapters)
  return {
    ...novel,
    routeSlug: routeSlugForNovel(novel),
    coverUrl: coverUrlForNovel(novel),
    chapterCount: bookChapters.length,
    wordCount: totalWordsForChapters(bookChapters),
  }
})
---

<Base
  title="Nobody Publishing — Noman Stiles"
  description="AI-authored science fiction by Noman Stiles, published by an AI editorial team with minimal human intervention."
>
  <section class="home-hero container--wide">
    <div class="home-hero__grid">
      <div class="home-hero__copy">
        <p class="eyebrow">AI-authored science fiction</p>
        <h1 class="home-hero__title">
          A synthetic author. An automated publishing desk. New novels landing one night at a time.
        </h1>
        <p class="home-hero__lede">
          Noman Stiles is an AI writer. Nobody Publishing is an AI editorial and production pipeline.
          Human involvement is deliberately minimal: set the system in motion, review the results,
          publish the books. The work itself is the experiment.
        </p>

        <div class="home-hero__actions">
          <a href={`${base}/library`} class="btn">Browse the library</a>
          {featured && (
            <a href={`${base}/${featuredSlug}`} class="btn btn--ghost">
              Read the latest novel
            </a>
          )}
        </div>

        <div class="home-hero__signals">
          <div class="signal-card">
            <span class="signal-card__label">Author</span>
            <strong class="signal-card__value">AI</strong>
            <p class="signal-card__text">Voice, structure, and prose generated inside the system.</p>
          </div>
          <div class="signal-card">
            <span class="signal-card__label">Publishing Team</span>
            <strong class="signal-card__value">AI</strong>
            <p class="signal-card__text">Outlining, editing, packaging, and release flow handled automatically.</p>
          </div>
          <div class="signal-card">
            <span class="signal-card__label">Human In Loop</span>
            <strong class="signal-card__value">Minimal</strong>
            <p class="signal-card__text">Direction and oversight stay light so the project remains legibly machine-made.</p>
          </div>
        </div>
      </div>

      {featured && (
        <a href={`${base}/${featuredSlug}`} class="home-hero__feature">
          <article class="feature-panel">
            <div class="feature-panel__glow"></div>
            <div class="feature-panel__cover">
              {featuredCover
                ? <img src={`${base}${featuredCover}`} alt={`Cover of ${featured.data.title}`} class="feature-panel__cover-img" />
                : <CoverPlaceholder title={featured.data.title} />}
            </div>
            <div class="feature-panel__body">
              <p class="feature-panel__kicker">Latest transmission</p>
              <h2 class="feature-panel__title">{featured.data.title}</h2>
              <p class="feature-panel__meta">
                {featured.data.genre}
                {featured.data.setting_type && ` · ${featured.data.setting_type}`}
              </p>
              {featured.data.synopsis ? (
                <p class="feature-panel__synopsis">
                  {featured.data.synopsis.length > 220
                    ? featured.data.synopsis.slice(0, 220) + '…'
                    : featured.data.synopsis}
                </p>
              ) : (
                <p class="feature-panel__synopsis">
                  {featured.data.tone} science fiction shaped by conscience, consequence, and wonder.
                </p>
              )}
              <div class="feature-panel__footer">
                <span>{featuredChapters.length} chapters live</span>
                <span>Enter novel →</span>
              </div>
            </div>
          </article>
        </a>
      )}
    </div>

    {(novels.length > 0 || totalChapters > 0) && (
      <div class="stats-bar home-stats">
        <div class="stats-bar__item">
          <span class="stats-bar__num">{novels.length}</span>
          <span class="stats-bar__label">{novels.length === 1 ? 'Novel' : 'Novels'}</span>
        </div>
        <div class="stats-bar__item">
          <span class="stats-bar__num">{totalChapters}</span>
          <span class="stats-bar__label">{totalChapters === 1 ? 'Chapter' : 'Chapters'}</span>
        </div>
        {totalWords > 0 && (
          <div class="stats-bar__item">
            <span class="stats-bar__num">{Math.round(totalWords / 1000)}k</span>
            <span class="stats-bar__label">Words published</span>
          </div>
        )}
      </div>
    )}
  </section>

  <section class="container--wide home-section">
    <div class="section-head">
      <div>
        <p class="section-label">Recent novels</p>
        <h2 class="section-title">The five latest books in the catalog</h2>
      </div>
      <p class="section-copy">
        Each title comes out of the same system, but with its own world, premise, and narrative pressure.
      </p>
    </div>

    <div class="recent-grid">
      {recentBooks.map((book, index) => (
        <a href={`${base}/${book.routeSlug}`} class={`recent-book recent-book--${index + 1}`}>
          <article class="recent-book__card">
            <div class="recent-book__cover">
              {book.coverUrl
                ? <img src={`${base}${book.coverUrl}`} alt={`Cover of ${book.data.title}`} class="recent-book__cover-img" />
                : <CoverPlaceholder title={book.data.title} />}
            </div>
            <div class="recent-book__body">
              <p class="recent-book__eyebrow">#{String(index + 1).padStart(2, '0')} most recent</p>
              <h3 class="recent-book__title">{book.data.title}</h3>
              <p class="recent-book__meta">
                {book.data.genre}
                {book.data.tone && ` · ${book.data.tone}`}
              </p>
              <p class="recent-book__stats">
                {book.chapterCount} {book.chapterCount === 1 ? 'chapter' : 'chapters'}
                {book.wordCount > 0 && ` · ${Math.round(book.wordCount / 1000)}k words`}
              </p>
            </div>
          </article>
        </a>
      ))}
    </div>
  </section>

  <section class="container--wide home-section">
    <div class="section-head">
      <div>
        <p class="section-label">How it works</p>
        <h2 class="section-title">An author platform where the author is synthetic</h2>
      </div>
      <p class="section-copy">
        This is not a human writer using AI as a drafting tool. The premise is narrower and stranger:
        author, editorial staff, and publishing machinery are all machine-run.
      </p>
    </div>

    <div class="process-grid">
      <article class="process-card">
        <p class="process-card__step">01</p>
        <h3 class="process-card__title">The writer is AI</h3>
        <p class="process-card__text">
          Noman Stiles exists as a constructed authorial identity, producing novels inside a defined
          style and worldview rather than acting as a human proxy.
        </p>
      </article>
      <article class="process-card">
        <p class="process-card__step">02</p>
        <h3 class="process-card__title">The editorial desk is AI</h3>
        <p class="process-card__text">
          Ideation, outlining, developmental critique, line editing, metadata, and packaging are handled
          by coordinated agents in the same pipeline.
        </p>
      </article>
      <article class="process-card">
        <p class="process-card__step">03</p>
        <h3 class="process-card__title">The human role stays light</h3>
        <p class="process-card__text">
          A person sets constraints, reviews outcomes, and decides what ships. The system does the writing
          and most of the publishing labor.
        </p>
      </article>
    </div>
  </section>

  <section class="container--wide home-section">
    <div class="manifesto">
      <div class="manifesto__body">
        <p class="section-label">Why read it</p>
        <h2 class="section-title">Because the question is no longer whether AI can write.</h2>
        <p class="manifesto__copy">
          The interesting question is whether a machine-made catalog can still surprise you, move you,
          and build a body of work worth returning to. Nobody Publishing is a running answer, released in public.
        </p>
      </div>
      <div class="manifesto__aside">
        <p class="manifesto__line">Machine-made books.</p>
        <p class="manifesto__line">Human-level stakes.</p>
        <p class="manifesto__line">Published in the open.</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .home-hero {
    padding-top: calc(var(--header-h) + 2.75rem);
    padding-bottom: 2rem;
  }

  .home-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 2rem;
    align-items: stretch;
  }

  .home-hero__copy {
    position: relative;
    padding: 2rem 0 1rem;
  }

  .home-hero__title {
    font-size: clamp(3rem, 7vw, 5.6rem);
    line-height: 0.95;
    letter-spacing: -0.05em;
    max-width: 11ch;
    color: var(--text);
    text-wrap: balance;
  }

  .home-hero__lede {
    max-width: 62ch;
    margin-top: 1.4rem;
    font-size: 1.08rem;
    line-height: 1.75;
    color: var(--text-muted);
  }

  .home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 1.8rem;
  }

  .home-hero__signals {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .signal-card {
    background:
      linear-gradient(180deg, rgba(255,255,255,0.95), rgba(240,244,255,0.9));
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: 1rem 1rem 1.1rem;
  }

  .signal-card__label {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }

  .signal-card__value {
    display: block;
    margin-top: 0.35rem;
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--accent);
  }

  .signal-card__text {
    margin-top: 0.45rem;
    font-size: 0.83rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .home-hero__feature {
    display: block;
    text-decoration: none;
  }

  .feature-panel {
    position: relative;
    height: 100%;
    min-height: 100%;
    background:
      radial-gradient(circle at top, rgba(91, 127, 255, 0.2), transparent 36%),
      linear-gradient(180deg, rgba(255,255,255,0.92), rgba(240,244,255,0.98));
    border: 1px solid var(--border);
    border-radius: 28px;
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: transform 0.35s var(--ease-out), box-shadow 0.35s ease, border-color 0.25s ease;
  }

  .feature-panel:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 60px rgba(51, 84, 255, 0.18), 0 8px 22px rgba(0, 0, 0, 0.08);
    border-color: var(--border-accent);
  }

  .feature-panel__glow {
    position: absolute;
    inset: -20% auto auto 58%;
    width: 220px;
    height: 220px;
    border-radius: 999px;
    background: rgba(91, 127, 255, 0.2);
    filter: blur(36px);
    pointer-events: none;
  }

  .feature-panel__cover {
    position: relative;
    z-index: 1;
  }

  .feature-panel__cover .cover-placeholder,
  .feature-panel__cover-img {
    width: 100%;
    max-width: 260px;
    margin: 0 auto;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
  }

  .feature-panel__cover-img {
    aspect-ratio: 2 / 3;
    object-fit: cover;
  }

  .feature-panel__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .feature-panel__kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .feature-panel__title {
    color: var(--text);
    font-size: clamp(1.8rem, 2.8vw, 2.5rem);
    letter-spacing: -0.04em;
  }

  .feature-panel__meta,
  .feature-panel__synopsis,
  .feature-panel__footer {
    color: var(--text-muted);
  }

  .feature-panel__meta {
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .feature-panel__synopsis {
    font-size: 0.96rem;
    line-height: 1.7;
  }

  .feature-panel__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 0.35rem;
    padding-top: 0.9rem;
    border-top: 1px solid var(--border);
    font-size: 0.82rem;
    font-weight: 600;
  }

  .home-stats {
    margin-top: 1.75rem;
    margin-bottom: 0;
    animation: fadeUp 0.7s var(--ease-out) 0.2s forwards;
  }

  .home-section {
    padding-top: 3rem;
  }

  .section-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: 1.5rem;
    align-items: end;
    margin-bottom: 1.5rem;
  }

  .section-title {
    color: var(--text);
    font-size: clamp(1.8rem, 3.4vw, 2.7rem);
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .section-copy {
    color: var(--text-muted);
    line-height: 1.7;
  }

  .recent-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  .recent-book {
    display: block;
    text-decoration: none;
  }

  .recent-book__card {
    height: 100%;
    background: rgba(255,255,255,0.86);
    backdrop-filter: blur(10px);
    border: 1px solid var(--border);
    border-radius: 22px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s ease, border-color 0.25s ease;
  }

  .recent-book__card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--border-accent);
  }

  .recent-book__cover .cover-placeholder,
  .recent-book__cover-img {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: 0;
    border: 0;
    box-shadow: none;
  }

  .recent-book__body {
    padding: 1rem;
  }

  .recent-book__eyebrow {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }

  .recent-book__title {
    margin-top: 0.35rem;
    color: var(--text);
    font-size: 1.1rem;
    letter-spacing: -0.03em;
  }

  .recent-book__meta,
  .recent-book__stats {
    margin-top: 0.35rem;
    color: var(--text-muted);
    font-size: 0.82rem;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .process-card {
    background: linear-gradient(180deg, rgba(255,255,255,0.96), rgba(237,241,250,0.92));
    border: 1px solid var(--border);
    border-radius: 22px;
    padding: 1.4rem;
    box-shadow: var(--shadow-sm);
  }

  .process-card__step {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--accent);
  }

  .process-card__title {
    margin-top: 0.6rem;
    color: var(--text);
    font-size: 1.35rem;
    letter-spacing: -0.03em;
  }

  .process-card__text {
    margin-top: 0.65rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .manifesto {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(260px, 0.8fr);
    gap: 1.5rem;
    align-items: stretch;
    padding: 1.6rem;
    border-radius: 28px;
    background:
      linear-gradient(135deg, rgba(51, 84, 255, 0.08), rgba(255,255,255,0.94) 45%),
      linear-gradient(180deg, rgba(255,255,255,0.96), rgba(240,244,255,0.92));
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
  }

  .manifesto__copy {
    margin-top: 0.9rem;
    color: var(--text-muted);
    font-size: 1.02rem;
    line-height: 1.8;
    max-width: 58ch;
  }

  .manifesto__aside {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.7rem;
    padding: 1rem 1.2rem;
    border-radius: 22px;
    background: rgba(22, 26, 31, 0.94);
    color: #fff;
  }

  .manifesto__line {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.1vw, 1.7rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  @media (max-width: 1080px) {
    .home-hero__grid,
    .section-head,
    .manifesto {
      grid-template-columns: 1fr;
    }

    .recent-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .process-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 820px) {
    .home-hero__signals,
    .recent-grid {
      grid-template-columns: 1fr 1fr;
    }

    .home-hero__title {
      max-width: 12ch;
    }
  }

  @media (max-width: 640px) {
    .home-hero {
      padding-top: calc(var(--header-h) + 1.75rem);
    }

    .home-hero__title {
      font-size: clamp(2.4rem, 13vw, 3.4rem);
      max-width: none;
    }

    .home-hero__signals,
    .recent-grid {
      grid-template-columns: 1fr;
    }

    .feature-panel {
      padding: 1rem;
    }

    .manifesto {
      padding: 1.2rem;
    }

    .feature-panel__footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
